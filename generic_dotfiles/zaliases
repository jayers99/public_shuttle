#------------------------------------------------------------------------------
# Typora
#------------------------------------------------------------------------------
# usage: typ [path] — opens folder (default: cwd) in Typora with File Tree view
typ() {
  local dir="${1:-$PWD}"
  dir="$(cd "$dir" 2>/dev/null && pwd)" || { echo "typ: no such directory: $1" >&2; return 1; }
  open -a Typora "$dir"
}

