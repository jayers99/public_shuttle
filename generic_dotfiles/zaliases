#------------------------------------------------------------------------------
# Files & directories
#------------------------------------------------------------------------------
alias ls='ls -G'
alias ll='ls -lhG'
alias la='ls -lahG'
alias lll='ls -1'
alias lsf='ls -1d "$PWD"/*'
alias lt='find . -maxdepth 2 -print'
alias tree='find . -print'
alias lS='ls -lhS'
alias lm='ls -lt'
alias md='mkdir -p'

#------------------------------------------------------------------------------
# Search & text
#------------------------------------------------------------------------------
alias grep='rg --smart-case'
alias rg='rg --smart-case'
alias tfgrep='rg -t tf'
help() { "$@" --help 2>&1 | bathelp; }

#------------------------------------------------------------------------------
# History
#------------------------------------------------------------------------------
alias hist='history 60'
alias rhist='history | cut -c 8- | tail -n 20'
alias shist="history | tail -r -n 200 | cut -c 8- | sed -e '/^echo startsession/q' | tail -r"
alias hg='history | command grep '
alias hcds='history | grep cd | grep -vw "cd .."'
alias hvims='history | grep vim'
alias hgits='history | grep git'

#------------------------------------------------------------------------------
# Git & GitHub
#------------------------------------------------------------------------------
alias glog='git --no-pager log --oneline -n10'
# usage: ghprc <language> — defaults to Python
ghprc() { gh repo create "$(basename "$PWD")" --private --add-readme --license MIT --gitignore "${1:-Python}"; }

#------------------------------------------------------------------------------
# Docker
#------------------------------------------------------------------------------
alias dil='docker image ls --format "{{json .}}" | jq -r '\''. | select((.Repository | contains("k8s")) or (.Repository | contains("docker/")) or (.Repository | contains("buildkit")) | not) | "\(.ID),\(.Repository),\(.Tag),\(.Size)"'\'' | column -t -s, | sort -k 2'
alias dipl='for i in $(docker image ls --format "{{json .}}" | jq -r '\''. | select(.Tag == "latest") | .Repository'\''); do echo $i; docker image pull $i; done && docker image prune -f'
alias dit='docker run -u 0 -it -v $PWD:/mnt/pwd --entrypoint /bin/sh --rm'

#------------------------------------------------------------------------------
# Python
#------------------------------------------------------------------------------
alias py="uv run python"

#------------------------------------------------------------------------------
# Infrastructure
#------------------------------------------------------------------------------
alias tf='terraform'
alias k='kubectl'
alias ek="eksctl"

