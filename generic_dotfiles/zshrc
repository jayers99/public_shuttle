#---------------------------------------------------------------------
# functions
#---------------------------------------------------------------------
f() {
  local sel
  sel=$(fd . ~ --no-ignore-vcs --type f | fzf --scheme=path) || return
  if [[ -z "$1" ]]; then
    open "$sel"
  elif [[ "$1" == *'{}'* ]]; then
    eval "${@//\{\}/\"$sel\"}"
  else
    "$@" "$sel"
  fi
}

d() {
  local sel
  sel=$(fd . ~ --no-ignore-vcs --type d | fzf --scheme=path) || return
  if [[ -z "$1" ]]; then
    cd "$sel"
  elif [[ "$1" == *'{}'* ]]; then
    eval "${@//\{\}/\"$sel\"}"
  else
    "$@" "$sel"
  fi
}

snipit() {
  [ -n "${1}" ] && snip_file="${1}" || snip_file='snippets.sh'
  echo "" >> "$snip_file"
  read "?Enter comment: " comment
  [ -n "${comment}" ] && echo "# ${comment}" >> "$snip_file"
  fc -ln -1 | gsed '1s/^[[:space:]]*//' >> "$snip_file"
  [ -n "${comment}" ] && tail -n 2 "$snip_file" || tail -n 1 "$snip_file"
}


