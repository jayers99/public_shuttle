#---------------------------------------------------------------------
# Vendored prompt theme (was oh-my-zsh themes/jayers.zsh-theme)
# omz isn't installed here, so the theme is inlined. `colors` is a
# built-in zsh autoload (not omz-specific) that defines $fg[],
# $fg_bold[], and $reset_color used below.
#---------------------------------------------------------------------
autoload -U colors && colors
setopt PROMPT_SUBST

jayers_git_prompt() {
    local dir="${PWD}"
    local git_dir
    git_dir=$(command git -C "$dir" rev-parse --git-dir 2>/dev/null) || return
    case "$git_dir" in
        /*) ;;
        *) git_dir="$dir/$git_dir" ;;
    esac

    local status_output
    status_output=$(command git -C "$dir" status --porcelain=v2 --branch --untracked-files=normal 2>/dev/null) || return

    local branch="" ahead=0 behind=0 detached=""
    local has_staged=0 has_unstaged=0 has_untracked=0
    local line xy ab
    while IFS= read -r line; do
        case "$line" in
            "# branch.head "*)
                branch="${line#\# branch.head }"
                [[ "$branch" == "(detached)" ]] && detached=1
                ;;
            "# branch.ab "*)
                ab="${line#\# branch.ab }"
                ahead="${ab#+}"
                ahead="${ahead%% *}"
                behind="${ab##*-}"
                ;;
            "1 "*|"2 "*)
                xy="${line[3,4]}"
                [[ "${xy[1]}" != "." ]] && has_staged=1
                [[ "${xy[2]}" != "." ]] && has_unstaged=1
                ;;
            "u "*)
                has_unstaged=1
                ;;
            "? "*)
                has_untracked=1
                ;;
        esac
    done <<< "$status_output"

    if [[ -n "$detached" ]]; then
        local sha
        sha=$(command git -C "$dir" rev-parse --short=7 HEAD 2>/dev/null)
        branch="HEAD@${sha}"
    elif (( ${#branch} > 25 )); then
        branch="${branch[1,24]}…"
    fi

    local state=""
    if [[ -d "$git_dir/rebase-merge" ]]; then
        local msgnum end
        msgnum=$(cat "$git_dir/rebase-merge/msgnum" 2>/dev/null)
        end=$(cat "$git_dir/rebase-merge/end" 2>/dev/null)
        if [[ -n "$msgnum" && -n "$end" ]]; then
            state="|REBASE ${msgnum}/${end}"
        else
            state="|REBASE"
        fi
    elif [[ -d "$git_dir/rebase-apply" ]]; then
        local next last
        next=$(cat "$git_dir/rebase-apply/next" 2>/dev/null)
        last=$(cat "$git_dir/rebase-apply/last" 2>/dev/null)
        if [[ -n "$next" && -n "$last" ]]; then
            state="|REBASE ${next}/${last}"
        else
            state="|REBASE"
        fi
    elif [[ -f "$git_dir/MERGE_HEAD" ]]; then
        state="|MERGING"
    elif [[ -f "$git_dir/CHERRY_PICK_HEAD" ]]; then
        state="|CHERRY-PICK"
    elif [[ -f "$git_dir/REVERT_HEAD" ]]; then
        state="|REVERTING"
    elif [[ -f "$git_dir/BISECT_LOG" ]]; then
        state="|BISECTING"
    fi

    local stash_count
    stash_count=$(command git -C "$dir" rev-list --walk-reflogs --count refs/stash 2>/dev/null)
    stash_count=${stash_count:-0}

    local out=" %{$fg[blue]%}("
    if [[ -n "$detached" ]]; then
        out+="%{$fg[yellow]%}${branch}%{$fg[blue]%}"
    else
        out+="%{$fg[green]%}${branch}%{$fg[blue]%}"
    fi
    [[ -n "$state" ]] && out+="%{$fg[red]%}${state}%{$fg[blue]%}"
    if (( ahead > 0 && behind > 0 )); then
        out+="%{$fg[yellow]%}↑${ahead}↓${behind}%{$fg[blue]%}"
    elif (( ahead > 0 )); then
        out+="%{$fg[green]%}↑${ahead}%{$fg[blue]%}"
    elif (( behind > 0 )); then
        out+="%{$fg[yellow]%}↓${behind}%{$fg[blue]%}"
    fi
    out+=")%{$reset_color%}"
    (( has_staged )) && out+="%{$fg[green]%}+%{$reset_color%}"
    (( has_unstaged )) && out+="%{$fg[red]%}*%{$reset_color%}"
    (( has_untracked )) && out+="%{$fg[yellow]%}?%{$reset_color%}"
    (( stash_count > 0 )) && out+="%{$fg[magenta]%}⚑${stash_count}%{$reset_color%}"

    printf '%s' "$out"
}

# SSH detection: orange hostname when remote, bold yellow when local
if [[ -n "$SSH_CONNECTION" ]]; then
  PROMPT='%B%F{208}%m%f%b:'
else
  PROMPT='%{$fg_bold[yellow]%}%m%{$reset_color%}:'
fi
PROMPT+='%{$fg[cyan]%}%1~%{$reset_color%}$(jayers_git_prompt)'
PROMPT+=$'\n%(?.%{$fg[green]%}.%{$fg[red]%})%B%#%b '
