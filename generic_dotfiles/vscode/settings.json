{
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
  },
  "[terraform]": { "editor.tabSize": 2 },
  "cSpell.userWords": [
    "agentic",
    "ansible",
    "atlassian",
    "boto",
    "botostubs",
    "braindumps",
    "Brodner's",
    "ctoth's",
    "decisionable",
    "decoupler",
    "devkit",
    "devs",
    "disconfirming",
    "Essentia",
    "eudaimonia",
    "heredocs",
    "htmlcov",
    "Huikang's",
    "IDAS",
    "Imran",
    "jayers",
    "jira",
    "Maccy",
    "mypy",
    "Phronesis",
    "PKDP",
    "pycache",
    "pyproject",
    "pytest",
    "Reclassifiable",
    "reconstructability",
    "reconstructable",
    "reindexing",
    "Runbook",
    "runbooks",
    "Sidetool",
    "Telos",
    "timebomb",
    "timebox",
    "tsdevau's",
    "typer",
    "venv",
    "WCAG",
  ],
  "chatgpt.lang": "en",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "python.defaultInterpreterPath": ".venv/bin/python",
  "editor.fontFamily": "Monaco, Menlo, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "all",
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": false,
  "files.associations": { "*.env": "shellscript" },
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true,
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "macros": {
    "saveRun": ["workbench.action.files.save", "python.execInTerminal"],
  },
  "notebook.cellToolbarLocation": { "default": "right", "jupyter-notebook": "left" },
  "prettier.printWidth": 100,
  "python.analysis.extraPaths": ["lib/python"],
  "python.languageServer": "Pylance",
  "redhat.telemetry.enabled": true,
  "remote.extensionKind": { "ms-azuretools.vscode-docker": "workspace" },
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.external.osxExec": "warp.app",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.fontFamily": "Monaco, Menlo, 'Courier New', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeightBold": "normal",
  "terminal.integrated.rightClickBehavior": "paste",
  "terminal.integrated.scrollback": 4000,
  "typescript.referencesCodeLens.enabled": true,
  "vsicons.dontShowNewVersionMessage": true,
  "window.newWindowDimensions": "inherit",
  "window.openFilesInNewWindow": "default",
  "window.restoreWindows": "none",
  "window.title": "${rootName}${separator}${activeEditorShort}",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editorAssociations": { "*.ipynb": "jupyter-notebook" },
  "workbench.iconTheme": "vscode-icons",
  "yaml.customTags": [
    "!And",
    "!If",
    "!Not",
    "!Equals",
    "!Or",
    "!FindInMap sequence",
    "!Base64",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Join sequence",
  ],
  "yaml.format.enable": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "remote.defaultExtensionsIfInstalledLocally": [
    "GitHub.copilot",
    "GitHub.copilot-chat",
    "GitHub.vscode-pull-request-github",
  ],
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "default",
  "chat.viewSessions.orientation": "stacked",
  "chat.editor.fontSize": 15,
  "chat.fontSize": 15,
  "chat.tools.urls.autoApprove": {
    "https://marketplace.visualstudio.com": {
      "approveRequest": false,
      "approveResponse": true,
    },
  },
  "python.analysis.typeCheckingMode": "basic",
  "chat.tools.terminal.autoApprove": {
    "$HOME/<WORKSPACE>/.venv/bin/python": true,
    "pytest": true,
    "git checkout": true,
    "git stash": true,
    "gh": true,
    "git rev-parse": true,
    "git remote": true,
    "command": true,
    "true": true,
    "git pull": true,
    "git add": true,
    "git commit": true,
    "git push": true,
    "sed": true,
    "/^cd $HOME/<WORKSPACE>/praxis-ai && git --no-pager status --porcelain=v1$/": {
      "approve": true,
      "matchCommandLine": true,
    },
    "praxis": true,
    "npx markdownlint-cli2": true,
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "chat.agent.maxRequests": 50,
  "explorer.compactFolders": false,
  "scm.compactFolders": false,
  "git.openRepositoryInParentFolders": "never",
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "chat.mcp.gallery.enabled": true,
  "terminal.integrated.env.osx": {
    "PATH": "",
  },
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "text": "For Python: always use uv for package management. Use 'uv run' for script execution. For standalone scripts, include PEP 723 inline metadata (# /// script block) declaring dependencies. For projects, use project-local .venv at the repo root. Never install packages into system or Homebrew Python. Use 'uv init' for new projects, 'uv add' for dependencies.",
    },
  ],
  "python.terminal.activateEnvironment": false,
  "workbench.startupEditor": "none",
  "workbench.colorTheme": "Dark Modern",
}
