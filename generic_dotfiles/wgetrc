# Retry failed downloads
tries = 5
retry_connrefused = on
waitretry = 5

# Timeout settings (seconds)
timeout = 30
dns_timeout = 10
connect_timeout = 15
read_timeout = 30

# Randomize wait between retries (polite to servers)
random_wait = on

# Continue partially downloaded files
continue = on

# Use server timestamps for downloaded files
timestamping = on

# Don't go up to parent directory when recursing
no_parent = on
